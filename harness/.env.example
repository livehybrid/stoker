# Stoker integration harness -- copy to .env and `set -a; . ./.env; set +a`
# (or export these in your shell / CI secrets). Nothing here is committed.

# --- required: the control plane + an operator API token --------------------
STOKER_URL=https://stoker.cloud.livehybrid.com
STOKER_TOKEN=stk_xxxxxxxxxxxxxxxxxxxxxxxx        # operator role (see README: minting)
# STOKER_VERIFY_TLS=false                         # set true if the cert is trusted
# STOKER_TEST_FLEET=swarm-local                   # the live fleet name

# --- live-run tests: a HEC target to deliver to -----------------------------
# A lab HEC endpoint + token, and indexes you can search and purge.
STOKER_TEST_HEC_URL=https://hec.example.internal:8088
STOKER_TEST_HEC_TOKEN=00000000-0000-0000-0000-000000000000
# STOKER_TEST_HEC_VERIFY_TLS=false
STOKER_TEST_INDEX=loadtest                        # an EVENTS index (eventgen run)
STOKER_TEST_METRIC_INDEX=loadtest_metrics         # a METRICS-type index (metrics run)
# STOKER_TEST_EVENTGEN_PACK=flatline              # an existing synced eventgen pack

# --- kept small on purpose (storage + search stay cheap) --------------------
# STOKER_TEST_EPS=5                                # eventgen run rate
# STOKER_TEST_DURATION_S=15                        # eventgen run length
# STOKER_TEST_BACKFILL_WINDOW_S=300               # metrics backfill window
# STOKER_TEST_BACKFILL_RES_S=30                   # metrics backfill step
# STOKER_TEST_POLL_TIMEOUT_S=240                  # wait for a run to finish

# --- optional: Splunk, for the count assertions -----------------------------
# Without these the e2e tests assert the run's delivered total only.
SPLUNK_URL=https://splunk.example.internal:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
# SPLUNK_TOKEN=eyJ...                              # bearer token instead of user/pass
