# Stoker control-plane deploy config. Copy to .env (git-ignored) and fill in.
# deploy.py reads this file (and the process env) and injects these into the
# swarm stack via the Portainer API.

# --- Portainer (required) --- the control plane also uses these at runtime to
# drive the SwarmDriver, so they are projected into the container too.
PORTAINER_HOST=192.168.0.112
PORTAINER_TOKEN=            # tier-0 Portainer API key (X-API-Key)
PORTAINER_ENDPOINT=6

# --- Database (required) ---
STOKER_DB_PASSWORD=         # Postgres password for the stoker user

# --- Where workers reach the control plane (required for real runs) ---
# The URL a launched worker uses for claim/heartbeat/bundle. On the LAN this is
# a swarm node IP and the published port, e.g. http://192.168.0.112:8091
STOKER_PUBLIC_BASE_URL=

# --- Worker image the control plane launches (optional; sensible default) ---
STOKER_WORKER_IMAGE=ghcr.io/livehybrid/stoker-worker:latest

# --- Optional self-telemetry (dogfood: the control plane ships its own logs) ---
DOGFOOD_HEC_URL=
DOGFOOD_HEC_TOKEN=

# --- Master key (managed automatically) ---
# Leave unset on first deploy: deploy.py generates a Fernet key, appends it here
# and creates the `stoker_master_key` swarm secret from it. It protects every
# Fernet-encrypted secret (target tokens, repo credentials), so keep this file
# safe and back it up. Do NOT commit .env.
# STOKER_MASTER_KEY=
