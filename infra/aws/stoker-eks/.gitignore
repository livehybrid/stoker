# Terraform working artefacts (regenerated by `terraform init`).
.terraform/
.terraform.tfstate.lock.info

# State: never commit (remote backend holds it; see README "State").
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Real tfvars carry site-specific / SOPS-decrypted secrets; only the example is tracked.
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Provider lock file .terraform.lock.hcl is intentionally NOT ignored:
# it pins provider selections and should be committed.
